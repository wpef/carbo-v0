generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MigrationPlan {
  id                      String    @id @default(uuid())
  name                    String
  description             String?
  status                  String    @default("DRAFT") // DRAFT | READY | BROKEN
  currentStep             String    @default("SOURCE_CONNECTION")
  sourceConnectionId      String?
  destinationConnectionId String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  auditLogs             AuditLog[]
  sourceConnection      SourceConnection?
  destinationConnection DestinationConnection?
}

model SourceConnection {
  id          String    @id @default(uuid())
  planId      String    @unique
  adapterType String
  status      String    @default("PENDING") // PENDING | CONNECTED | EXPIRED | ERROR
  config      String    @default("{}") // JSON blob: adapter-specific config
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan MigrationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model DestinationConnection {
  id          String    @id @default(uuid())
  planId      String    @unique
  adapterType String
  status      String    @default("PENDING")
  config      String    @default("{}")
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan MigrationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  planId    String?
  action    String
  details   String? // JSON string
  createdAt DateTime @default(now())

  plan MigrationPlan? @relation(fields: [planId], references: [id], onDelete: Cascade)
}
