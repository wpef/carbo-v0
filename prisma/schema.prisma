generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MigrationPlan {
  id                      String    @id @default(uuid())
  name                    String
  description             String?
  status                  String    @default("DRAFT") // DRAFT | READY | BROKEN
  currentStep             String    @default("SOURCE_CONNECTION")
  sourceConnectionId      String?
  destinationConnectionId String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  auditLogs             AuditLog[]
  sourceConnection      SourceConnection?
  destinationConnection DestinationConnection?
  objectMappings        ObjectMapping[]
}

model ObjectMapping {
  id                  String   @id @default(uuid())
  planId              String
  sourceObjectId      String
  sourceObjectApiName String
  destObjectId        String
  destObjectApiName   String
  status              String   @default("ACTIVE") // ACTIVE | BROKEN
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  plan MigrationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, sourceObjectApiName])
  @@index([planId])
}

model SourceConnection {
  id          String    @id @default(uuid())
  planId      String    @unique
  adapterType String
  status      String    @default("PENDING") // PENDING | CONNECTED | EXPIRED | ERROR
  config      String    @default("{}") // JSON blob: adapter-specific config
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan MigrationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model DestinationConnection {
  id          String    @id @default(uuid())
  planId      String    @unique
  adapterType String
  status      String    @default("PENDING")
  config      String    @default("{}")
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan MigrationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model SchemaSnapshot {
  id           String   @id @default(uuid())
  connectionId String
  role         String   // "source" | "destination"
  status       String   @default("CURRENT") // CURRENT | PREVIOUS
  objectCount  Int      @default(0)
  retrievedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  objects    SchemaObject[]
  selections ObjectSelection[]
  fields     ObjectField[]

  @@index([connectionId, role, status])
}

model SchemaObject {
  id          String  @id @default(uuid())
  snapshotId  String
  apiName     String
  label       String
  description String?
  isCustom    Boolean @default(false)

  snapshot   SchemaSnapshot    @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  selections ObjectSelection[]
  fields     ObjectField[]

  @@unique([snapshotId, apiName])
}

model ObjectField {
  id               String   @id @default(uuid())
  objectId         String
  snapshotId       String
  apiName          String
  label            String
  dataType         String
  isRequired       Boolean  @default(false)
  isReadOnly       Boolean  @default(false)
  isUnique         Boolean  @default(false)
  isAccessible     Boolean  @default(true)
  referenceTo      String?
  relationshipType String?
  createdAt        DateTime @default(now())

  object   SchemaObject   @relation(fields: [objectId], references: [id], onDelete: Cascade)
  snapshot SchemaSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([objectId, apiName])
  @@index([objectId])
  @@index([snapshotId])
}

model ObjectSelection {
  id            String    @id @default(uuid())
  snapshotId    String
  objectId      String
  objectApiName String
  isSelected    Boolean   @default(false)
  selectedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  snapshot SchemaSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  object   SchemaObject   @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, objectId])
  @@index([snapshotId, isSelected])
}

model AuditLog {
  id        String   @id @default(uuid())
  planId    String?
  action    String
  details   String? // JSON string
  createdAt DateTime @default(now())

  plan MigrationPlan? @relation(fields: [planId], references: [id], onDelete: Cascade)
}
