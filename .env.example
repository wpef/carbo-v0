# --- Database ---
DATABASE_URL="file:./dev.db"

# --- LLM rule descriptions (optional — only needed for feature 018) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Salesforce Connected App (OAuth2 + PKCE) ---
# Create a Connected App in Setup → App Manager with these settings:
#   - Enable OAuth Settings: checked
#   - Callback URL: must match SALESFORCE_CALLBACK_URL exactly
#   - OAuth Scopes: "Full access (full)" + "Perform requests at any time (refresh_token)"
#   - Require PKCE: checked (mandatory on modern Connected Apps)
#   - IP Relaxation: "Relax IP restrictions"
#   - Permitted Users: "All users may self-authorize"
# After creating the app, wait 10-15 minutes for SF to propagate.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_CALLBACK_URL=http://localhost:3001/api/connectors/salesforce/callback
# Production / Developer Edition / Agentforce orgs: https://login.salesforce.com
# Sandbox orgs only (username ends in .sandbox.my.salesforce.com): https://test.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# --- HubSpot App (OAuth2) ---
# Create an app at https://app.hubspot.com/developer → Apps → Create app.
# Add the redirect URL matching HUBSPOT_CALLBACK_URL, and grant scopes for
# contacts/companies/deals/tickets/line_items (read+write, schema read+write),
# plus custom objects (requires Enterprise portal).
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_CALLBACK_URL=http://localhost:3001/api/connectors/hubspot/callback
