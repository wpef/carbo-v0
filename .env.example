# ─── Lot 0: Base de données (Neon Postgres) ───
# Pooled connection (host en "-pooler") — utilisée par l'app au runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct connection (sans "-pooler") — utilisée par les migrations Prisma
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# ─── Lot 1: Salesforce (source) — Connected App OAuth ───
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_LOGIN_URL=https://login.salesforce.com

# ─── Lot 2: HubSpot (destination) — App OAuth ───
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# ─── Lots 1-2: callbacks OAuth + chiffrement des tokens ───
# APP_URL=http://localhost:3000
# ENCRYPTION_KEY= # 32 octets en base64 — chiffre les tokens OAuth stockés en base
